{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "AI MIDI Composer - opencode project config. Agents e skills sao descobertos automaticamente em .opencode/.",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "ask",
    "skill": "allow",
    "question": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow"
  },
  "agent": {
    "build": { "description": "Engineer padrao para implementacao do AI MIDI Composer." },
    "plan": { "description": "Planejamento/analise sem edicoes." }
  }
}
